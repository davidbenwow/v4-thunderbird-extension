{
  "manifest_version": 2,
  "name": "V4 Contacts Checker",
  "version": "1.18.6",
  "description": "Checks whether email addresses in Thunderbird messages are already leads in V4 Contacts, and lets you jump to the lead's page in v4.vdm-vsg.de to mark it.",
  "browser_specific_settings": {
    "gecko": {
      "id": "v4-contacts@snap-collective.com",
      "strict_min_version": "115.0",
      "update_url": "https://davidbenwow.github.io/v4-thunderbird-extension/updates.json"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "96": "images/icon-96.png"
  },
  "permissions": [
    "messagesRead",
    "addressBooks",
    "compose",
    "storage",
    "sensitiveDataUpload",
    "https://v4.vdm-vsg.de/*"
  ],
  "background": {
    "scripts": [
      "scripts/internal-domains.js",
      "scripts/background.js"
    ]
  },
  "options_ui": {
    "page": "popup-settings.html",
    "open_in_tab": true
  },
  "message_display_action": {
    "default_title": "V4 Contacts \u2014 check this message",
    "default_icon": {
      "16": "images/icon-16.png",
      "19": "images/icon-19.png",
      "32": "images/icon-32.png",
      "38": "images/icon-38.png"
    },
    "default_popup": "popup-status.html"
  },
  "compose_action": {
    "default_title": "V4 Contacts \u2014 check recipients",
    "default_icon": {
      "16": "images/icon-16.png",
      "19": "images/icon-19.png",
      "32": "images/icon-32.png",
      "38": "images/icon-38.png"
    },
    "default_popup": "popup-status.html"
  }
}
